# Express API — default port 8080 (frontend Next.js uses 3000)
PORT=8080

# MongoDB (either variable works)
MONGO_URI=
# MONGODB_URI=

# ALLOW_START_WITHOUT_DB=true

JWT_SECRET=
JWT_REFRESH_SECRET=

EMAIL_USER=
EMAIL_PASS=

# Express public URL (verification links). Not the Next.js URL.
BACKEND_PUBLIC_URL=http://localhost:8080
CLIENT_URL=http://localhost:3000

# Optional unauthenticated rate limiting
# PUBLIC_RATE_LIMIT_WINDOW_MS=900000
# PUBLIC_RATE_LIMIT_MAX=120
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=20

# CORS_ORIGIN=http://localhost:3001
# DEV_AUTO_VERIFY=true
